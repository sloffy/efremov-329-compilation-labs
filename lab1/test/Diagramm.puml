@startuml
skinparam linetype ortho
skinparam nodesep 15
skinparam ranksep 25
skinparam rectangle {
    BackgroundColor #2C3E50
    BorderColor #1A252F
    FontColor white
    FontStyle bold
    RoundCorner 8
}
skinparam node {
    BackgroundColor #ECF0F1
    BorderColor #3498DB
    FontColor #2C3E50
    RoundCorner 5
}
skinparam arrow {
    Color #7F8C8D
    Thickness 1
}

top to bottom direction

rectangle "TaxiFleetManager" as Root

' Уровень 1 - порядок слева направо: 1.1, 1.2, 1.3, 1.4, 1.5, 1.6, 1.7
node "1.1 Анализ требований" as L11
node "1.2 Проектирование" as L12
node "1.3 Разработка бэкенда" as L13
node "1.4 Разработка фронтенда" as L14
node "1.5 Тестирование" as L15
node "1.6 Документирование" as L16
node "1.7 Подготовка к релизу" as L17

Root --> L11
Root --> L12
Root --> L13
Root --> L14
Root --> L15
Root --> L16
Root --> L17

' Скрытые связи слева направо (1.1 -> 1.2 -> 1.3 -> ...)
L11 -[hidden]right-> L12
L12 -[hidden]right-> L13
L13 -[hidden]right-> L14
L14 -[hidden]right-> L15
L15 -[hidden]right-> L16
L16 -[hidden]right-> L17

